  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2962e9be10870bd469a99ef0a686c23b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NarrativeGP.Emails.EmailsController
  gameState: {fileID: 1878978060}
  emails:
  - id: 01
    subject: Welcome to Verifiers
    sender: Shaw (Head of Verifiers)
    dateText: 17/07/2025 09:03
    arrivalDay: 1
    sortOrder: 0
    body: "Welcome to Department of Verifiers. Your mailbox has been migrated. Historical
      emails from your previous working Department of Reviewers will sync over the
      next few days.\r\n\r\nDaily tasks are configured in Workbench. Reach out if
      you run into issues.\r\n\r\n\u2014 Shaw"
  - id: 02
    subject: Department Monthly Performance Report
    sender: Gina (HR)
    dateText: 18/07/2025 09:10
    arrivalDay: 2
    sortOrder: 0
    body: "Department Performance Ranking \u2014 June\r\n\r\n  1. Verifiers       
      500%\r\n  2. Reviewers        120%\r\n  3. Moderators        95%\r\n  4. Annotators       
      88%\r\n\r\nVerifiers exceeded operational targets by 500%, ranking first across
      all departments.\r\n\r\nMonthly bonus will be doubled across the team.\r\n\r\n\u2014
      Gina"
  - id: 03
    subject: Overtime Allowance Eligibility
    sender: Gina (HR)
    dateText: 18/07/2025 09:16
    arrivalDay: 2
    sortOrder: 0
    body: "Employees clocking out after 23:00 for 7 consecutive days may apply for
      overtime pay.\r\nReply to confirm eligibility.\r\n\r\nNote: No clock-out record
      is treated as on-time departure.\r\n\r\n\u2014 Gina"
  - id: 04
    subject: '[Archived] Free this weekend?'
    sender: Archive System
    dateText: 18/07/2025 09:00
    arrivalDay: 2
    sortOrder: 0
    body: "=====================================\r\n  From:  Abby (Reviewers)\r\n 
      Date:  10/07/2025 21:34\r\n=====================================\r\n\r\nHey,
      long time no talk!!\r\n\r\nHeard through the grapevine that someone on your
      team got hospitalized AGAIN? \r\nLike what are you guys doing over there, the
      project pushing that hard?? \r\nSeriously worried about you, please take care
      of yourself ok.\r\n\r\nAnyway \u2014 are you free this Saturday? Usual place?
      It's been literally months since we all got together.\r\nMark, Jenna, even
      Chris said he's coming (miracle I know).\r\nDrinks are on me if you show up.\r\n\r\nReply
      when you surface from the overtime pit lol.\r\nMiss you.\r\n\r\n\u2014 Abby"
  - id: 05
    subject: '[Archived] Project Update'
    sender: Archive System
    dateText: 18/07/2025 09:00
    arrivalDay: 2
    sortOrder: 0
    body: "=====================================\r\n  From:  Evan (Head of Reviewers)\r\n 
      Date:  08/07/2025 19:42\r\n=====================================\r\n\r\nHeard
      about Ryan? He's gone. Pick up his tasks.\r\n\r\nMilestone review is Friday.
      Ryan's tasks are in the shared board \u2014 filter by his name, they're all
      yours now. I need you to carry this one.\r\n\r\n\u2014 Evan"
  - id: 06
    subject: Confidentiality Reminder
    sender: Gina (HR)
    dateText: 19/07/2025 09:02
    arrivalDay: 3
    sortOrder: 0
    body: "Internal information has been detected on external platforms. All employees
      must strictly observe confidentiality agreements.\r\n\r\nTo prevent further
      information leaks, access to certain internal documents and external sites
      will be restricted.\r\n\r\n\u2014 Gina"
  - id: 07
    subject: '[Archived] Medical Report'
    sender: Archive System
    dateText: 20/07/2025 09:00
    arrivalDay: 4
    sortOrder: 0
    body: "=====================================\r\n  From:  healthcare@neuromecha.com\r\n 
      Date:  02/07/2025 16:30\r\n=====================================\r\n\r\nName:
      [Not Registered]\r\nExam Date: 02/07/2025\r\n----------------------------------------\r\nECG:            
      ABNORMAL (ST depression)\r\nBlood Pressure:  ABNORMAL (168/106 mmHg)\r\nCBC:            
      NORMAL\r\nLiver Function:  ABNORMAL (Elevated ALT)\r\n----------------------------------------\r\nRecommendation:
      Cease high-intensity work.\r\nFollow-up examination required."
  - id: 08
    subject: "[Archived] Retiring \u2014 come grab a drink"
    sender: Archive System
    dateText: 21/07/2025 09:00
    arrivalDay: 5
    sortOrder: 0
    body: "Kid,\r\n\r\nWell, it's official. Paperwork cleared this morning. Twenty-three
      years at this company \u2014 next Friday is my last.\r\n\r\nI know you've only
      been with us six months, but honestly, you've picked it up faster than I ever
      did. Keep that curiosity. The senior ones around here, they forget to ask questions.
      Don't end up like that.\r\n\r\nSmall farewell at The Tipsy Crow, Friday night
      after 7. Drinks on me. Bring that terrible tie you wore to onboarding, it'll
      be funny.\r\n\r\nTake care of yourself, kid. This place will grind you down
      if you let it.\r\n\r\n\u2014 Shaw"
  - id: 09
    subject: '[Archived] Contract Amendment - Action Required'
    sender: Archive System
    dateText: 21/07/2025 09:00
    arrivalDay: 5
    sortOrder: 0
    body: "=====================================\r\n  From:  legal@neuromecha.com\r\n 
      Date:  08/07/2024 10:35\r\n=====================================\r\n\r\nEmployee:
      Ben [B072]\r\n\r\nYour contract has been updated to v3.2.\r\n----------------------------------------\r\nAppendix
      A \u2014 Digital Re-employment (Voluntary)\r\n\r\nArt.1 Employee authorizes
      the Company to extend employment via retained neural data in the event of force
      majeure (death, incapacity, etc.).\r\n\r\nArt.2 Compensation during extension:
      30% of base, paid to designated beneficiary.\r\n\r\nAppendix B \u2014 Neural
      Asset Acquisition\r\n\r\nArt.1 The Company holds full ownership and\r\ndisposal
      rights over the Employee's neural data.\r\n\r\nArt.7 This agreement is irrevocable
      upon signing.\r\n----------------------------------------\r\nE-signature: __Ben__\r\nSigned:
      08/07/2024 10:30\r\nSTATUS: ACTIVE"
  mailListContent: {fileID: 1927510571}
  mailItemPrefab: {fileID: 746308259495215250, guid: 74602958f38c40b4789b15db0f0ff8e3, type: 3}
  subjectText: {fileID: 1137090403}
